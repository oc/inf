# OpenTofu
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.example.tfvars
crash.log
# .terraform.lock.hcl IS tracked — keeps provider versions reproducible

# Decrypted secrets (never commit)
secrets.yaml
secrets.json
*.dec
*.decrypted

# Cloud-init rendered output
cloud-init/*.rendered.yaml

# Local
.DS_Store
.envrc
.env
*.log

# Editors
.idea/
.vscode/
*.swp
